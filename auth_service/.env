# Copia este archivo como .env y ajusta los valores
# NUNCA subas .env a control de versiones

SECRET_KEY=django123456*$
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Credenciales compartidas de PostgreSQL
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Nombres de las bases de datos CQRS
WRITE_DB_NAME=airbnb_write
READ_DB_NAME=airbnb_read
